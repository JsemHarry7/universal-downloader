# Firebase web config — optional. Leave blank to disable cross-device sync.
# Get these from Firebase console → Project settings → Your apps → Web.
# These values are public-by-design; security is enforced by firestore.rules.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
